{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "command": "cd mystore && celery -A mystore.celery_app worker -E -l info",
            "windows": {
                "command": "cd mystore && celery -A mystore.celery_app worker -E --loglevel=INFO --pool=solo"
            },
            "icon": {
                "id": "database"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$",
                    "file": 1,
                    "message": 2
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^celery@.*starting",
                    "endsPattern": "ready\\.$"
                }
            },
            "detail": "Starts Celery",
            "label": "Celery: start",
            "isBackground": true
        }
    ]
}
