{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/services/addresses/.venv/bin/uvicorn",
            "cwd": "${workspaceFolder}/services/addresses",
            "args": [
                "app:app",
                "--reload",
                "--port",
                "8000"
            ],
            "jinja": true,
            "justMyCode": true,
            "presentation": {
                "hidden": false,
                "group": "FastApi",
                "order": 1
            }
        },
        {
            "name": "Services: Authentication",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/services/myauthentication",
            "presentation": {
                "hidden": false,
                "group": "Golang",
                "order": 1
            }
        },
        {
            "name": "Services: Purchase",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/services/purchase",
            "presentation": {
                "hidden": false,
                "group": "Golang",
                "order": 1
            }
        },
        {
            "name": "Django: Shop",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mystore/manage.py",
            "args": ["runserver"],
            "envFile": "${workspaceFolder}/mystore/.env",
            // "preLaunchTask": "Celery: start",
            "django": true,
            "presentation": {
                "hidden": false,
                "group": "Django",
                "order": 1
            }
        },
        {
            "name": "Django: Cart",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mycart/manage.py",
            "args": [
                "runserver",
                "8001"
            ],
            "envFile": "${workspaceFolder}/mycart/.env",
            "preLaunchTask": "Celery: start",
            "django": true,
            "presentation": {
                "hidden": false,
                "group": "Django",
                "order": 1
            }
        },
        {
            "name": "Django: Reviews",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/myreviews/manage.py",
            "args": [
                "runserver"
            ],
            "envFile": "${workspaceFolder}/myreviews/.env",
            "django": true,
            "presentation": {
                "hidden": false,
                "group": "Django",
                "order": 1
            }
        },
        {
            "name": "Django: Celery Shop",
            "type": "debugpy",
            "request": "launch",
            "module": "celery",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/mystore",
            "args": [
                "-A",
                "mystore.celery_app",
                "worker",
                "-E",
                "--loglevel=INFO",
                "--pool=solo"
            ],
            "envFile": "${workspaceFolder}/mystore/.env",
            "presentation": {
                "hidden": false,
                "group": "Django",
                "order": 2
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "client: My commerce",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/frontend/app",
        },
        {
            "type": "node",
            "request": "launch",
            "name": "server: My commerce",
            "outputCapture": "std",
            "cwd": "${workspaceFolder}/frontend",
            "program": "${workspaceFolder}/frontend/node_modules/nuxt/bin/nuxt.mjs",
            "envFile": "${workspaceFolder}/frontend/.env",
            "args": [
                "dev"
            ]
        },
        {
            "name": "Flutter",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/mymobile/lib/main.dart",
        }
    ],
    "compounds": [
        {
            "name": "My commerce: nuxt",
            "configurations": [
                "server: My commerce",
                "client: My commerce"
            ]
        }
    ]
}
