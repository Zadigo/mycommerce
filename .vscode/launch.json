{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/services/addresses/.venv/bin/uvicorn",
            "cwd": "${workspaceFolder}/services/addresses",
            "args": [
                "app:app",
                "--reload",
                "--port",
                "8000"
            ],
            "jinja": true,
            "justMyCode": true,
            "presentation": {
                "hidden": false,
                "group": "FastApi",
                "order": 1
            }
        },
        {
            "name": "Services: Authentication",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/services/goauthentication",
            "presentation": {
                "hidden": false,
                "group": "Golang",
                "order": 1
            }
        },
        {
            "name": "Services: Purchase",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/services/gopurchase",
            "presentation": {
                "hidden": false,
                "group": "Golang",
                "order": 1
            }
        },
        {
            "name": "Django: ShopApi",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/services/shopapi/.venv/bin/python",
            "program": "${workspaceFolder}/services/shopapi/manage.py",
            "args": ["runserver"],
            "envFile": "${workspaceFolder}/services/shopapi/.env",
            // "preLaunchTask": "Celery: start",
            "django": true,
            "presentation": {
                "hidden": false,
                "group": "Django",
                "order": 1
            }
        },
        {
            "name": "Django: Cart",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mycart/manage.py",
            "args": [
                "runserver",
                "8001"
            ],
            "envFile": "${workspaceFolder}/mycart/.env",
            "preLaunchTask": "Celery: start",
            "django": true,
            "presentation": {
                "hidden": false,
                "group": "Django",
                "order": 1
            }
        },
        {
            "name": "Django: Reviews",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/myreviews/manage.py",
            "args": [
                "runserver"
            ],
            "envFile": "${workspaceFolder}/myreviews/.env",
            "django": true,
            "presentation": {
                "hidden": false,
                "group": "Django",
                "order": 1
            }
        },
        {
            "name": "Celery: Shop Worker",
            "type": "debugpy",
            "request": "launch",
            "module": "celery",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/mystore",
            "args": [
                "-A",
                "mystore.celery_app",
                "worker",
                "-E",
                "--loglevel=INFO",
                "--pool=solo"
            ],
            "envFile": "${workspaceFolder}/mystore/.env",
            "presentation": {
                "hidden": false,
                "group": "Django",
                "order": 2
            }
        },
        {
            "name": "Flutter: Mobile App",
            "type": "dart",
            "request": "launch",
            "program": "${workspaceFolder}/mymobile/lib/main.dart",
            "presentation": {
                "hidden": false,
                "group": "Flutter",
                "order": 1
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Nuxt: My commerce (Client)",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/frontend/mainsite/app",
            "presentation": {
                "hidden": false,
                "group": "Nuxt",
                "order": 1
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Nuxt: My commerce (Server)",
            "outputCapture": "std",
            "cwd": "${workspaceFolder}/frontend/mainsite",
            "program": "${workspaceFolder}/frontend/mainsite/node_modules/nuxt/bin/nuxt.mjs",
            "envFile": "${workspaceFolder}/frontend/mainsite/.env",
            "args": [
                "dev"
            ],
            "presentation": {
                "hidden": false,
                "group": "Nuxt",
                "order": 1
            }
        }
    ],
    "compounds": [
        {
            "name": "Nuxt Website",
            "configurations": [
                "Nuxt: My commerce (Server)",
                "Nuxt: My commerce (Client)"
            ],
            "preLaunchTask": "GoPurchase",
            "presentation": {
                "hidden": false,
                "group": "Nuxt",
                "order": 1
            }
        }
    ]
}
